# Current web detector: yunet (default CPU prototype), openvino (RetinaFace
# reference), or tensorflow (legacy RetinaFace reference).
PROJECTBLUR_DETECTOR=yunet

# OpenVINO device: AUTO (default), CPU, or a verified available device.
PROJECTBLUR_OPENVINO_DEVICE=AUTO

# Optional override. The default is the repository-local model generated by
# scripts/prepare_openvino_retinaface.ps1.
# PROJECTBLUR_OPENVINO_MODEL=C:\path\to\retinaface-resnet50-pytorch.xml

# Optional YuNet override. The default is the repository-local model generated
# by scripts/prepare_yunet.ps1.
# PROJECTBLUR_YUNET_MODEL=C:\path\to\face_detection_yunet_2026may.onnx
